# OSS Pulse — environment variables
# Copy to .env, fill in real values, never commit .env to version control.
# All secrets are loaded from this file via python-dotenv at startup.

# ── GitHub ───────────────────────────────────────────────────────────────────
# Personal access token with read:public_repo scope (5000 req/hr limit).
# Create at: https://github.com/settings/tokens → "Fine-grained" or "Classic"
# Minimum scopes required: public_repo (read-only).
GITHUB_TOKEN=ghp_replace_with_your_token

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Provider name passed to LiteLLM (e.g. openai, anthropic, ollama).
# Matches the [llm] provider = "..." value in config.toml.
# Use "ollama" for local inference — no API key required for Ollama.
LLM_PROVIDER=openai

# API key for the configured LLM provider.
# OpenAI:    https://platform.openai.com/account/api-keys
# Anthropic: https://console.anthropic.com/
# Ollama:    leave unset (local inference, no key needed).
LLM_API_KEY=sk-replace_with_your_api_key

# ── State store ───────────────────────────────────────────────────────────────
# Path where the JSON state file is written (tracks seen items for idempotency).
# The directory is created automatically on first run.
# Default: ./.osspulse/state.json — override only if needed.
# STATE_PATH=./.osspulse/state.json

# ── Redis cache (optional) ────────────────────────────────────────────────────
# Redis connection URL for the LLM summary cache adapter.
# When unset or Redis is unreachable, caching degrades gracefully (every run
# re-calls the LLM for unseen items — safe, just more expensive).
# REDIS_URL=redis://localhost:6379/0

# ── Discord delivery (optional) ───────────────────────────────────────────────
# Webhook URL for Discord push delivery (destination = "discord" in config.toml).
# Create at: Discord server → channel ⚙️ → Integrations → Webhooks → New Webhook → Copy URL
# Must be https://discord.com/api/webhooks/... or https://discordapp.com/...
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/replace_with_id/replace_with_token
