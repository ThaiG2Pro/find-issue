{
  "name": "rtk",
  "description": "RTK-enabled agent — automatically redirects shell commands through RTK for 60-90% token savings",
  "hooks": {
    "preToolUse": [
      {
        "matcher": "execute_bash",
        "command": "rtk hook kiro",
        "timeout_ms": 5000
      }
    ]
  },
  "resources": [
    {
      "type": "knowledgeBase",
      "source": "file://./.kiro/steering",
      "name": "Steering",
      "indexType": "best",
      "autoUpdate": false
    },
    {
      "type": "knowledgeBase",
      "source": "file://./.kiro/openspec",
      "name": "Openspec",
      "indexType": "best",
      "autoUpdate": false
    },
    {
      "type": "knowledgeBase",
      "source": "file://./.kiro/sdlc.config.json",
      "name": "Sdlc.config",
      "indexType": "best",
      "autoUpdate": false
    },
    {
      "type": "knowledgeBase",
      "source": "file://./.kiro/context/project.md",
      "name": "Project",
      "indexType": "best",
      "autoUpdate": false
    },
    {
      "type": "knowledgeBase",
      "source": "file://./.kiro/context/glossary.md",
